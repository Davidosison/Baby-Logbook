{
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm install --frozen-lockfile && BASE_PATH=/ PORT=3000 pnpm run build",
  "outputDirectory": "artifacts/newborn-tracker/dist/public",
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
